Content/**/*_Backup_AutoBefore*
Content/**/*_Backup_Before*

# Local Wwise plugin installs are too large for normal Git history.
# Install Wwise/Unreal integration locally instead of committing the SDK.
Plugins/Wwise/
Plugins/WwiseMotionOpenXRHelpers/
Plugins/WwiseNiagara/
Plugins/WwiseSoundEngine/
